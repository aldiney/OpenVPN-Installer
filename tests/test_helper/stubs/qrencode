#!/usr/bin/env bash
# Stub do 'qrencode' para os testes. Registra os argumentos, consome a entrada
# padrão (o .ovpn) e cria o arquivo indicado por '-o <arquivo>' (PNG simulado).

printf '%s\n' "$*" >> "${STUB_CALLS_DIR:?STUB_CALLS_DIR não definido}/qrencode"

prev=""
for arg in "$@"; do
    if [[ "${prev}" == "-o" ]]; then
        printf 'STUB-PNG\n' > "${arg}"
    fi
    prev="${arg}"
done

cat > /dev/null
exit "${STUB_QRENCODE_EXIT:-0}"
